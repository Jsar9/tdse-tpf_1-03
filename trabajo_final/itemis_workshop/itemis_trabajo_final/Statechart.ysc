      <vertices xsi:type="sgraph:State" xmi:id="_1eCRwOwYEfC-RMLmfypfoA" name="ST_LOW_TEMP" incomingTransitions="_YHiVAOwcEfC-RMLmfypfoA _3sye8OwxEfC-RMLmfypfoA _YIQoIOyoEfC0iuHtelXmNg _X8nyoBAEEfGTM-u_k8g7QA">
        <outgoingTransitions xmi:id="_NAbIkOwaEfC-RMLmfypfoA" specification="TEMP_INCREASING [temp >= LOW_TEMP_VALUE] / raise turn_on_yellow_led ; raise turn_off_green_led" target="__kchEOwYEfC-RMLmfypfoA"/>
        <outgoingTransitions xmi:id="_YHiVAOwcEfC-RMLmfypfoA" specification="TEMP_INCREASING [temp &lt; LOW_TEMP_VALUE] / raise turn_on_green_led" target="_1eCRwOwYEfC-RMLmfypfoA"/>
        <outgoingTransitions xmi:id="_3sye8OwxEfC-RMLmfypfoA" specification="TEMP_DECREASING [temp &lt; LOW_TEMP_VALUE] / raise turn_on_green_led" target="_1eCRwOwYEfC-RMLmfypfoA"/>
