        <outgoingTransitions xmi:id="_0FV74OyZEfC0iuHtelXmNg" specification="TEMP_INCREASING [temp >= CL_TEMP_VALUE &amp;&amp; temp &lt; HIGH_TEMP_VALUE &amp;&amp; !cooler] / raise turn_on_yellow_led ; cooler = true ; raise turn_on_cl_led" target="__kchEOwYEfC-RMLmfypfoA"/>
        <outgoingTransitions xmi:id="_oj-VAOyaEfC0iuHtelXmNg" specification="TEMP_INCREASING [temp >= HIGH_TEMP_VALUE] / raise turn_off_yellow_led ; raise turn_on_red_led" target="_CGMFEOwZEfC-RMLmfypfoA"/>
